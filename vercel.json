{
  "version": 2,
  "builds": [
    {
      "src": "api/index.go",
      "use": "@vercel/go"
    }
  ],
  "routes": [
    {
      "src": "/projects",
      "dest": "/api/index.go"
    },
    {
      "src": "/projects/(.*)",
      "dest": "/api/index.go"
    },
    {
      "src": "/contact",
      "dest": "/api/index.go"
    },
    {
      "src": "/ping",
      "dest": "/api/index.go"
    }
  ]
}